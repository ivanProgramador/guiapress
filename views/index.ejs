<%- include('partials/header.ejs')%>
<%- include('partials/homenavbar.ejs')%>

<body>


    <div class="container" >
        <hr>
        <div class="jumbotron mt-3 ">
            <h1 class="display-4">Bem vindo !</h1>
            <p class="lead">Este é o meu blog</p>
            <hr class="my-4">
            <p>Estes blog contem artigos úteis sobre assuntos variados </p>
            <a class="btn btn-primary btn-lg" href="#" role="button">Leia mais</a>
          </div>
        <hr>



    <% articles.forEach(article =>{%>

        <hr>
        <div class="card">
            <div class="card-header">
                <h3><%= article.title %></h3>
            </div>
            <div class="card-body" >
                <a class="btn btn-success" href="/<%= article.slug %>">Ler artigo</a>
            </div>

        </div><br>
                 
           
          
     <% }) %>
       <div class="row">
       <div class="col col-md-12">

          <a href="/articles/page/2" style="float:right">Next >>></a>
          
       </div>
    </div>
       

    </div>
    
</body>


<%- include('partials/footer.ejs')%>